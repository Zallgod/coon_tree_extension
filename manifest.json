{
  "manifest_version": 3,
  "name": "Coon Tree",
  "version": "6.0.0",
  "description": "Workspace tab manager with tree integrity, duplicate prevention, and crash recovery.",
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "permissions": ["tabs", "storage", "favicon"],
  "action": {
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
    "default_title": "Coon Tree"
  },
  "background": { "service_worker": "js/background.js" },
  "commands": {
    "save_close_current_window": {
      "suggested_key": { "default": "Ctrl+Shift+S" },
      "description": "Save and close current window"
    }
  },
  "web_accessible_resources": [{
    "resources": ["_favicon/*"],
    "matches": ["<all_urls>"],
    "extension_ids": ["*"]
  }]
}
